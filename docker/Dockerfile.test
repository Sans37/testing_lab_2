 # Dockerfile.test (исправленная версия с правильным синтаксисом)
FROM python:3.11-slim

WORKDIR /app

# Установка системных зависимостей
RUN apt-get update && apt-get install -y \
    gcc \
    postgresql-client \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Копируем зависимости
COPY requirements.txt .

# Устанавливаем Python зависимости
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Копируем исходный код и скрипты
COPY src/ ./src/
COPY scripts/ ./scripts/
COPY pytest.ini .
COPY .env.example .env

# Исправляем порт в скриптах (5433 -> 5432) через sed
RUN sed -i 's/5433/5432/g' scripts/*.py

# Делаем скрипты исполняемыми
RUN chmod +x scripts/*.py

# Создаем директории для результатов тестов
RUN mkdir -p /app/test-results/unit \
    /app/test-results/integration \
    /app/test-results/e2e \
    /app/coverage-report

# Создаем скрипт для запуска тестов
RUN echo '#!/bin/bash' > /app/run_tests.sh && \
    echo 'set -e' >> /app/run_tests.sh && \
    echo '' >> /app/run_tests.sh && \
    echo 'echo "=========================================="' >> /app/run_tests.sh && \
    echo 'echo "🚀 ЗАПУСК ТЕСТОВ В DOCKER"' >> /app/run_tests.sh && \
    echo 'echo "=========================================="' >> /app/run_tests.sh && \
    echo '' >> /app/run_tests.sh && \
    echo '# Ожидание PostgreSQL' >> /app/run_tests.sh && \
    echo 'echo "⏳ Ожидание PostgreSQL..."' >> /app/run_tests.sh && \
    echo 'for i in {1..30}; do' >> /app/run_tests.sh && \
    echo '    if PGPASSWORD="${DB_PASSWORD:-test_pass}" pg_isready -h "${DB_HOST:-localhost}" -p "${DB_PORT:-5432}" -U "${DB_USER:-test_user}"; then' >> /app/run_tests.sh && \
    echo '        echo "✅ PostgreSQL готов!"' >> /app/run_tests.sh && \
    echo '        break' >> /app/run_tests.sh && \
    echo '    fi' >> /app/run_tests.sh && \
    echo '    echo "  Ждем... ($i/30)"' >> /app/run_tests.sh && \
    echo '    sleep 2' >> /app/run_tests.sh && \
    echo 'done' >> /app/run_tests.sh && \
    echo '' >> /app/run_tests.sh && \
    echo '# Unit тесты' >> /app/run_tests.sh && \
    echo 'echo ""' >> /app/run_tests.sh && \
    echo 'echo "1. 🧪 UNIT ТЕСТЫ"' >> /app/run_tests.sh && \
    echo 'echo "=========================================="' >> /app/run_tests.sh && \
    echo 'python -m pytest src/tests/unit/ -v \' >> /app/run_tests.sh && \
    echo '  --junitxml=test-results/unit/junit.xml \' >> /app/run_tests.sh && \
    echo '  --cov=src \' >> /app/run_tests.sh && \
    echo '  --cov-report=xml:coverage-report/coverage-unit.xml \' >> /app/run_tests.sh && \
    echo '  --cov-report=html:coverage-report/unit \' >> /app/run_tests.sh && \
    echo '  --alluredir=test-results/unit' >> /app/run_tests.sh && \
    echo '' >> /app/run_tests.sh && \
    echo '# Integration тесты' >> /app/run_tests.sh && \
    echo 'echo ""' >> /app/run_tests.sh && \
    echo 'echo "2. 🔗 INTEGRATION ТЕСТЫ"' >> /app/run_tests.sh && \
    echo 'echo "=========================================="' >> /app/run_tests.sh && \
    echo 'python scripts/cleanup_test_db.py 2>/dev/null || true' >> /app/run_tests.sh && \
    echo 'python scripts/init_test_db.py' >> /app/run_tests.sh && \
    echo 'python -m pytest src/tests/integration/ -v -m integration \' >> /app/run_tests.sh && \
    echo '  --junitxml=test-results/integration/junit.xml \' >> /app/run_tests.sh && \
    echo '  --cov=src --cov-append \' >> /app/run_tests.sh && \
    echo '  --cov-report=xml:coverage-report/coverage-integration.xml \' >> /app/run_tests.sh && \
    echo '  --cov-report=html:coverage-report/integration \' >> /app/run_tests.sh && \
    echo '  --alluredir=test-results/integration' >> /app/run_tests.sh && \
    echo 'python scripts/cleanup_test_db.py 2>/dev/null || true' >> /app/run_tests.sh && \
    echo '' >> /app/run_tests.sh && \
    echo '# E2E тесты' >> /app/run_tests.sh && \
    echo 'echo ""' >> /app/run_tests.sh && \
    echo 'echo "3. 🎯 E2E ТЕСТЫ"' >> /app/run_tests.sh && \
    echo 'echo "=========================================="' >> /app/run_tests.sh && \
    echo 'python scripts/init_test_db.py' >> /app/run_tests.sh && \
    echo 'python -m pytest src/tests/e2e/ -v -m e2e \' >> /app/run_tests.sh && \
    echo '  --junitxml=test-results/e2e/junit.xml \' >> /app/run_tests.sh && \
    echo '  --cov=src --cov-append \' >> /app/run_tests.sh && \
    echo '  --cov-report=xml:coverage-report/coverage-e2e.xml \' >> /app/run_tests.sh && \
    echo '  --cov-report=html:coverage-report/e2e \' >> /app/run_tests.sh && \
    echo '  --alluredir=test-results/e2e' >> /app/run_tests.sh && \
    echo 'python scripts/cleanup_test_db.py 2>/dev/null || true' >> /app/run_tests.sh && \
    echo '' >> /app/run_tests.sh && \
    echo 'echo ""' >> /app/run_tests.sh && \
    echo 'echo "✅ ТЕСТИРОВАНИЕ ЗАВЕРШЕНО"' >> /app/run_tests.sh && \
    echo 'echo "=========================================="' >> /app/run_tests.sh

# Делаем скрипт исполняемым
RUN chmod +x /app/run_tests.sh

# Основная команда
CMD ["/app/run_tests.sh"]